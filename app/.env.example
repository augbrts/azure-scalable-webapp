# Copie para .env apenas em desenvolvimento local. NUNCA comite o .env real.
# Em produção (VMSS), estas variáveis são injetadas pelo cloud-init.

PORT=8080
PROJECT_NAME=Byte Academy

# Banco gerenciado (Azure Database for MySQL Flexible Server)
DB_HOST=changeme.mysql.database.azure.com
DB_USER=dbadmin
DB_PASS=changeme
DB_NAME=appdb
DB_PORT=3306

# Object storage (Azure Blob)
STORAGE_ACCOUNT=changeme
BLOB_CONTAINER=materiais
